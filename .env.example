# -----------------------------------------------------
# Example .env.example file for project configuration
#
# INSTRUCTIONS:
# 1. Copy this file to a new file named `.env` in the project root.
# 2. Fill in the necessary values in your `.env` file for your LOCAL setup.
# 3. Add the `.env` file to your `.gitignore` - DO NOT COMMIT IT TO GIT,
#    especially if it contains secrets like passwords or API keys.
# 4. This `.env.example` file SHOULD be committed to Git as a template.
# -----------------------------------------------------

# --- Dynaconf Configuration Paths ---
# These variables tell the Python configuration loader where to find settings files.
# Set these as actual environment variables in production/staging/CI.
# For local development, define them here if you are not setting them globally.
# Paths are typically relative to the project root for local dev.

# Comma-separated list of settings files. Order dictates override precedence.
# Example: SETTINGS_FILES=settings/settings.toml,settings/development.toml
SETTINGS_FILES="settings/settings.toml"


# --- Dynaconf Behavior ---

# Sets the current operational environment (e.g., development, production, testing).
# This controls which sections (like [development]) in settings files are active.
# Example: ENV_FOR_DYNACONF=development
ENV_FOR_DYNACONF="development"


# --- Application Specific Settings & Secrets ---
# Add required environment variables for your application below.
# Use placeholders like <your_value_here> or safe defaults for the example file.
# Dynaconf reads these from the environment (prefix ) which can be loaded
# from the actual .env file locally. Use '__' (double underscore) for nested keys.
SECURITY__SECRETS__BACKEND=vault
SECURITY__SECRETS__VAULT_TOKEN_PATH=./devtools/vault/env/vault.token
SECURITY__AUTH__JWT_SECRET_KEY=super-secret

# == External Service Example ==
THIRD_PARTY_API__URL="https://sandbox.api.example.com/v1"
THIRD_PARTY_API__KEY="<your_dev_api_key>" # Use a development/sandbox key

# == Logging Level Example ==
# Overrides log level set in settings files. Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"

# == Feature Flag Example ==
FEATURE_FLAGS__ENABLE_BETA_FEATURE="false"

RUN_INTEGRATION_TESTS="true" # Set to false in production
# --- CI/CD Environment Variables (Informational Only) ---
#
# The variables below are typically SET BY THE CI/CD PLATFORM (e.g., GitHub Actions, GitLab CI)
# during a pipeline run. Your application or CI/CD scripts can usually read these
# directly from the environment when running in the CI/CD context.
#
# You generally DO NOT need to set these variables in your local .env file.
# They are listed here purely for informational purposes / reference.
#

# == Common GitHub Actions Variables ==
# GITHUB_TOKEN=SECRET                   # For act use a personal access token
# GITHUB_ACTIONS="true"                 # Always true in GitHub Actions
# GITHUB_ACTOR="<username>"             # User who triggered the workflow
# GITHUB_EVENT_NAME="<event>"           # e.g., push, pull_request, workflow_dispatch
# GITHUB_REF_NAME="<branch/tag>"        # e.g., main, v1.0.0
# GITHUB_REPOSITORY="<owner/repo>"      # e.g., test-nala/athomic
# GITHUB_RUN_ID="<run_id>"              # Unique ID for the workflow run
# GITHUB_SHA="<commit_sha>"             # Commit SHA being built/tested/deployed
# GITHUB_WORKFLOW="<workflow_name>"     # Name of the workflow file
# RUNNER_OS="<os>"                      # e.g., Linux, Windows, macOS
# CI="true"                             # Standard variable indicating a CI environment

# == Common GitLab CI Variables ==
# CI="true"                             # Standard variable indicating a CI environment
# GITLAB_CI="true"                      # Always true in GitLab CI
# CI_COMMIT_REF_NAME="<branch/tag>"     # e.g., main, v1.0.0
# CI_COMMIT_SHA="<commit_sha>"          # Commit SHA being built/tested/deployed
# CI_PROJECT_DIR="<path>"               # Absolute path where the repo is cloned
# CI_PROJECT_NAME="<name>"              # Name of the GitLab project
# CI_PROJECT_NAMESPACE="<group/user>"   # Namespace of the project
# CI_PROJECT_URL="<url>"                # URL of the project
# CI_PIPELINE_ID="<pipeline_id>"        # Unique ID for the pipeline
# CI_JOB_ID="<job_id>"                  # Unique ID for the current job
# CI_RUNNER_ID="<runner_id>"            # ID of the runner executing the job
# CI_SERVER_URL="<instance_url>"        # URL of the GitLab instance (e.g., https://gitlab.com)
# GITLAB_USER_LOGIN="<username>"        # User who triggered the pipeline


# --- Add other required application variables below ---
# MY_OTHER_SETTING="default_value"

PROFILING_OUTPUT_DIR = .tests_history/profile

# Monitoring

OBSERVABILITY_METRICS_ALLOW_METRICS_IPS='["127.0.0.1", "172.28.0.10"]'

# Database
# MongoDB
MONGO_INITDB_ROOT_USERNAME=nala_user
MONGO_INITDB_ROOT_PASSWORD=nala_password
MONGO_TEST_URI=mongodb://nala_user:nala_password@localhost:27017,localhost:27018,localhost:27019/?replicaSet=rs0 # pragma: allowlist secret

# GCP

GCP_PROJECT_ID="nala-dev-ai" 
GCP_LOCATION="us-central1"
GOOGLE_APPLICATION_CREDENTIALS="/path/to/key.json"
GOOGLE_CLOUD_PROJECT_ID="athomic"
NALA_TEST_GCP_PROJECT_ID="athomic"
GOOGLE_CLOUD_LOCATION="us-east4"
GOOGLE_API_KEY="sample" # pragma: allowlist secret
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT="athomic"
MODEL_ID="gemini-2.0-flash-lite-001"


# Execution:
E2B_API_KEY="e2b_fff" # pragma: allowlist secret

# AI Models
OLLAMA_MODEL="llama3.2:1b"
